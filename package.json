{
  "name": "savant-sanctum",
  "version": "1.0.1",
  "private": true,
  "description": "Savant Sanctum desktop shell for workspace and session operations.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ashabbir/savant-sanctum.git"
  },
  "author": "Savant",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "rebuild:native": "npx @electron/rebuild -v 41.7.1 -f -m ../node_modules/better-sqlite3",
    "dev": "concurrently \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "node -e \"require('fs').rmSync('dist-electron', { recursive: true, force: true })\" && wait-on http://127.0.0.1:5175 && tsc -p tsconfig.electron.json && tsc -p tsconfig.preload.json && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5175 electron .",
    "build": "vite build && node -e \"require('fs').rmSync('dist-electron', { recursive: true, force: true })\" && tsc -p tsconfig.electron.json && tsc -p tsconfig.preload.json && electron-builder",
    "release:mac": "bash scripts/release-mac.sh",
    "build:renderer": "vite build",
    "build:electron": "node -e \"require('fs').rmSync('dist-electron', { recursive: true, force: true })\" && tsc -p tsconfig.electron.json && tsc -p tsconfig.preload.json",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "dependencies": {
    "@radix-ui/react-tooltip": "^1.2.10",
    "@types/d3": "^7.4.3",
    "better-sqlite3": "^12.10.0",
    "d3": "^7.9.0",
    "lucide-react": "^1.20.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "overrides": {
    "react": "$react",
    "react-dom": "$react-dom"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.12",
    "@types/node": "^24.0.10",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^5.0.2",
    "@vitest/coverage-v8": "^3.2.4",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^41.7.1",
    "electron-builder": "^26.0.12",
    "tailwindcss": "^4.1.12",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.8.3",
    "vite": "^7.0.4",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.savant.sanctum",
    "productName": "Savant Sanctum",
    "publish": [
      {
        "provider": "github",
        "owner": "ashabbir",
        "repo": "savant-sanctum"
      }
    ],
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json",
      "sanctum.svg",
      "tray.svg",
      "savant.png",
      "build/icons/**",
      "sanctum-roadmap-prd.md",
      "sanctum-style-guide.md"
    ],
    "mac": {
      "icon": "build/icons/sanctum.icns",
      "target": [
        "dmg"
      ]
    },
    "dmg": {
      "icon": "build/icons/sanctum.icns"
    }
  }
}
